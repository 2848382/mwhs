# ──────────────────────────────────────────────
# Supabase — Project Settings > Database 에서 복사
# ──────────────────────────────────────────────

# 일반 연결 (앱 실행용) — Connection Pooling > URI
DATABASE_URL=postgresql://postgres.[프로젝트ref]:[비밀번호]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# 직접 연결 (마이그레이션용) — Direct Connection > URI
DIRECT_URL=postgresql://postgres.[프로젝트ref]:[비밀번호]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# Supabase — Project Settings > API 에서 복사
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # 서버 전용, 절대 클라이언트에 노출 금지

# 앱 설정
VITE_OAUTH_PORTAL_URL=http://localhost:3000
VITE_APP_ID=myeonwon
